---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLibros, urlFor } from '../lib/sanity';

const libros = await getLibros();
---

<BaseLayout title="Libros" description="Libros y publicaciones académicas" showHeader={false}>
    <h1 class="mb-12 font-serif text-2xl leading-tight italic sm:mb-16 sm:text-4xl">Libros</h1>

    {libros.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {libros.map((pub) => (
                <a
                    href={pub.url || `/publicaciones/${pub.slug}`}
                    target={pub.url ? "_blank" : undefined}
                    rel={pub.url ? "noopener noreferrer" : undefined}
                    class="group block"
                >
                    {pub.coverImage && (
                        <div class="aspect-[2/3] rounded-lg overflow-hidden bg-gray-100 mb-4">
                            <img
                                src={urlFor(pub.coverImage).width(400).height(600).auto('format').url()}
                                alt=""
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                loading="lazy"
                            />
                        </div>
                    )}
                    <h3 class="font-serif text-lg leading-tight font-medium group-hover:underline group-hover:decoration-dashed group-hover:decoration-1 group-hover:underline-offset-4">
                        {pub.title}
                    </h3>
                    <p class="mt-1 text-sm opacity-70">{pub.year}</p>
                    {pub.description && (
                        <p class="mt-2 text-sm leading-relaxed">{pub.description}</p>
                    )}
                </a>
            ))}
        </div>
    ) : (
        <p class="text-center opacity-70">No hay libros disponibles.</p>
    )}
</BaseLayout>
