---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPrensa } from '../lib/sanity';

const prensa = await getPrensa();
---

<BaseLayout title="Prensa" description="Artículos de prensa y opinión" showHeader={false}>
    <h1 class="mb-12 font-serif text-2xl leading-tight italic sm:mb-16 sm:text-4xl">Prensa</h1>

    {prensa.length > 0 ? (
        <ul class="space-y-6">
            {prensa.map((pub) => (
                <li class="group">
                    <a
                        href={pub.url || `/publicaciones/${pub.slug}`}
                        target={pub.url ? "_blank" : undefined}
                        rel={pub.url ? "noopener noreferrer" : undefined}
                    >
                        <h3 class="font-serif text-lg leading-tight font-medium group-hover:underline group-hover:decoration-dashed group-hover:decoration-1 group-hover:underline-offset-4 sm:text-xl">
                            {pub.title}
                        </h3>
                        <p class="mt-1 text-sm opacity-70">{pub.year}</p>
                        {pub.description && (
                            <p class="mt-2 text-sm leading-relaxed">{pub.description}</p>
                        )}
                    </a>
                </li>
            ))}
        </ul>
    ) : (
        <p class="text-center opacity-70">No hay artículos de prensa disponibles.</p>
    )}
</BaseLayout>
