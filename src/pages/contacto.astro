---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contacto" description="Información de contacto" showHeader={false}>
    <h1 class="mb-12 font-serif text-2xl leading-tight italic sm:mb-16 sm:text-4xl">Contacto</h1>

    <div class="prose sm:prose-lg max-w-none mb-12">
        <p>
            Si deseas ponerte en contacto conmigo para consultas académicas, colaboraciones,
            entrevistas o cualquier otra cuestión, no dudes en escribirme a
            <a href="mailto:contacto@nicolasmarrero.uy" class="font-medium">contacto@nicolasmarrero.uy</a>
            o mediante el siguiente formulario.
        </p>
    </div>

    <form id="contact-form" class="max-w-lg space-y-6">
        <div>
            <label for="name" class="block text-sm font-medium mb-2">Nombre</label>
            <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-2 border border-current/20 rounded bg-transparent focus:outline-none focus:border-current/50"
            />
        </div>
        <div>
            <label for="email" class="block text-sm font-medium mb-2">Email</label>
            <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-2 border border-current/20 rounded bg-transparent focus:outline-none focus:border-current/50"
            />
        </div>
        <div>
            <label for="message" class="block text-sm font-medium mb-2">Mensaje</label>
            <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-2 border border-current/20 rounded bg-transparent focus:outline-none focus:border-current/50 resize-none"
            ></textarea>
        </div>
        <button
            type="submit"
            class="px-6 py-2 border border-current rounded hover:bg-current hover:text-white transition-colors"
        >
            Enviar mensaje
        </button>
        <p id="form-status" class="text-sm hidden"></p>
    </form>

</BaseLayout>

<script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const status = document.getElementById('form-status') as HTMLParagraphElement;

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        const originalText = submitBtn.textContent;
        submitBtn.textContent = 'Enviando...';
        submitBtn.disabled = true;

        const formData = new FormData(form);
        const data = {
            name: formData.get('name'),
            email: formData.get('email'),
            message: formData.get('message'),
        };

        try {
            const response = await fetch('/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data),
            });

            if (response.ok) {
                status.textContent = '¡Mensaje enviado! Gracias por contactarme.';
                status.className = 'text-sm text-green-600';
                form.reset();
            } else {
                throw new Error('Error al enviar');
            }
        } catch (error) {
            status.textContent = 'Error al enviar el mensaje. Por favor, intenta de nuevo.';
            status.className = 'text-sm text-red-600';
        } finally {
            status.classList.remove('hidden');
            submitBtn.textContent = originalText;
            submitBtn.disabled = false;
        }
    });
</script>
