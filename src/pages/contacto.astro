---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContacto } from '../lib/sanity';

const contacto = await getContacto();
---

<BaseLayout title="Contacto" description="Información de contacto" showHeader={false}>
    <h1 class="mb-12 font-serif text-2xl leading-tight italic sm:mb-16 sm:text-4xl">Contacto</h1>

    <div class="prose sm:prose-lg max-w-none">
        <p>
            Si deseas ponerte en contacto conmigo para consultas académicas, colaboraciones,
            entrevistas o cualquier otra cuestión, no dudes en escribirme.
        </p>

        {contacto?.email && (
            <p class="mt-8">
                <a
                    href={`mailto:${contacto.email}`}
                    class="inline-flex items-center gap-2 px-6 py-3 border border-current rounded hover:bg-current hover:text-white transition-colors"
                >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    {contacto.email}
                </a>
            </p>
        )}

        {contacto?.socialLinks && contacto.socialLinks.length > 0 && (
            <div class="mt-12">
                <h2 class="text-lg font-medium mb-4">Redes sociales</h2>
                <div class="flex gap-4">
                    {contacto.socialLinks.map((link) => (
                        <a
                            href={link.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="px-4 py-2 border border-current/20 rounded hover:border-current transition-colors"
                        >
                            {link.platform}
                        </a>
                    ))}
                </div>
            </div>
        )}
    </div>
</BaseLayout>
