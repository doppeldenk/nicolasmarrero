---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContacto } from '../lib/sanity';

const contacto = await getContacto();
---

<BaseLayout title="Contacto" description="Información de contacto" showHeader={false}>
    <h1 class="mb-12 font-serif text-2xl leading-tight italic sm:mb-16 sm:text-4xl">Contacto</h1>

    <div class="prose sm:prose-lg max-w-none">
        {contacto?.email && (
            <p>
                <strong>Email:</strong>{' '}
                <a href={`mailto:${contacto.email}`}>{contacto.email}</a>
            </p>
        )}

        {contacto?.socialLinks && contacto.socialLinks.length > 0 && (
            <>
                <h2 class="font-serif">Redes sociales</h2>
                <ul>
                    {contacto.socialLinks.map((link) => (
                        <li>
                            <a href={link.url} target="_blank" rel="noopener noreferrer">
                                {link.platform}
                            </a>
                        </li>
                    ))}
                </ul>
            </>
        )}

        {(!contacto || (!contacto.email && (!contacto.socialLinks || contacto.socialLinks.length === 0))) && (
            <p class="opacity-70">No hay información de contacto disponible.</p>
        )}
    </div>
</BaseLayout>
