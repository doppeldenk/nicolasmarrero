---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublicaciones, urlFor, type Publicacion } from '../../lib/sanity';

const publicaciones = await getPublicaciones();

// Group by type for filtering
const tipos = ['libro', 'articulo', 'charla', 'otro'] as const;
const tipoLabels: Record<string, string> = {
    libro: 'Libros',
    articulo: 'Artículos',
    charla: 'Charlas',
    otro: 'Otros'
};

// Get unique types that have publications
const availableTypes = tipos.filter(tipo =>
    publicaciones.some(p => p.type === tipo)
);
---

<BaseLayout title="Publicaciones" description="Publicaciones académicas y profesionales" showHeader={false}>
    <h1 class="mb-12 font-serif text-2xl leading-tight italic sm:mb-16 sm:text-4xl">Publicaciones</h1>

    {availableTypes.map(tipo => {
        const items = publicaciones.filter(p => p.type === tipo);
        if (items.length === 0) return null;

        return (
            <section class="mb-12 sm:mb-16">
                <h2 class="mb-6 font-serif text-xl italic sm:mb-8 sm:text-2xl">{tipoLabels[tipo]}</h2>
                <ul class="space-y-6">
                    {items.map((pub) => (
                        <li class="group">
                            <a
                                href={`/publicaciones/${pub.slug}`}
                                class="flex items-start gap-4"
                            >
                                {pub.coverImage && (
                                    <img
                                        src={urlFor(pub.coverImage).width(80).height(120).auto('format').url()}
                                        alt=""
                                        class="w-16 h-24 object-cover rounded shrink-0"
                                        loading="lazy"
                                    />
                                )}
                                <div class="grow">
                                    <h3 class="font-serif text-lg leading-tight font-medium group-hover:underline group-hover:decoration-dashed group-hover:decoration-1 group-hover:underline-offset-4 sm:text-xl">
                                        {pub.title}
                                    </h3>
                                    <p class="mt-1 text-sm opacity-70">{pub.year}</p>
                                    {pub.description && (
                                        <p class="mt-2 text-sm leading-relaxed">{pub.description}</p>
                                    )}
                                </div>
                            </a>
                        </li>
                    ))}
                </ul>
            </section>
        );
    })}

    {publicaciones.length === 0 && (
        <p class="text-center opacity-70">No hay publicaciones disponibles.</p>
    )}
</BaseLayout>
