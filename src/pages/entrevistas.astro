---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntrevistas, urlFor } from '../lib/sanity';

const entrevistas = await getEntrevistas();
---

<BaseLayout title="Entrevistas" description="Entrevistas y apariciones en medios" showHeader={false}>
    <h1 class="mb-12 font-serif text-2xl leading-tight italic sm:mb-16 sm:text-4xl">Entrevistas</h1>

    {entrevistas.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {entrevistas.map((video) => (
                <a
                    href={video.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group block"
                >
                    <div class="relative aspect-video rounded-lg overflow-hidden bg-gray-100">
                        <img
                            src={video.coverImage
                                ? urlFor(video.coverImage).width(480).height(270).auto('format').url()
                                : `https://i.ytimg.com/vi/${video.videoId}/hqdefault.jpg`}
                            alt=""
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                            loading="lazy"
                        />
                        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/20">
                            <div class="w-16 h-16 bg-red-600 rounded-full flex items-center justify-center">
                                <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M8 5v14l11-7z"/>
                                </svg>
                            </div>
                        </div>
                    </div>
                    <h3 class="mt-3 font-medium leading-snug group-hover:underline group-hover:decoration-dashed group-hover:underline-offset-4">
                        {video.title}
                    </h3>
                </a>
            ))}
        </div>
    ) : (
        <p class="text-center opacity-70">No hay entrevistas disponibles.</p>
    )}
</BaseLayout>
